Script.complete()
widget.presentSmall()

function parseHADatetime(raw) {
  if (!raw) return null
  if (/^\d{2}:\d{2}(:\d{2})?$/.test(raw)) {
    const today = new Date()
    const parts = raw.split(":")
    today.setHours(Number(parts[0]), Number(parts[1]), Number(parts[2] || 0), 0)
    return today
  }
  return new Date(raw.replace(" ", "T"))
}

async function fetchStates(entityIds) {
  const results = []
  for (const id of entityIds) {
    const req = new Request(hassUrl + "/api/states/" + id)
    req.headers = {
      "Authorization": "Bearer " + hassToken,
      "content-type": "application/json"
    }
    try {
      const s = await req.loadJSON()
      if (s && s.entity_id) results.push(s)
    } catch(e) {}
  }
  return results
}

function getState(states, entityId) {
  return states.find(function(s) { return s.entity_id === entityId })
}
